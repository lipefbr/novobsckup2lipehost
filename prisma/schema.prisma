// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  passwordHash  String
  role          String    @default("USER") // "USER" | "ADMIN"
  avatar        String?   // URL da foto de perfil (pode ser data URL ou URL externa)
  username      String?   // @username (display name público, opcional)
  phone         String?   // telefone (opcional)
  cpf           String?   // CPF (obrigatório para pagamentos, não editável após validar)
  // Endereço (opcional)
  addressStreet String?
  addressNumber String?
  addressComplement String?
  addressNeighborhood String?
  addressCity   String?
  addressState  String?   // UF (2 letras)
  addressZip    String?   // CEP
  // Assinatura
  plan          String    @default("FREE") // "FREE" | "STARTER" | "PRO" | "ENTERPRISE" ou custom
  planStatus    String    @default("active") // "active" | "canceled" | "past_due" | "trialing" | "suspended"
  planRenewalDate DateTime? // data de renovação (dia do mês que cobra)
  // Admin control — force site offline/online
  sitesForcedOffline Boolean @default(false) // se true, todos deploys do usuário param
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  projects      Project[]
  orders        Order[]
  deploys       Deploy[]
  tickets       Ticket[]
  databases     Database[]
  subscriptions Subscription[]
  payments      Payment[]
}

model SubscriptionPlan {
  id              String   @id @default(cuid())
  name            String   @unique // "STARTER", "PRO", etc
  slug            String   @unique
  description     String?
  priceMonthly    Float    // preço mensal em R$
  priceYearly     Float?   // preço anual em R$ (opcional, 10x monthly típico)
  features        String   // JSON string de features/benefícios
  maxDeploys      Int      @default(1)
  maxDatabases    Int      @default(1)
  maxCustomDomains Int     @default(0)
  isActive        Boolean  @default(true) // se false, não aparece para nova assinatura
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  subscriptions   Subscription[]
  payments        Payment[]
}

model Subscription {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  planId          String
  plan            SubscriptionPlan @relation(fields: [planId], references: [id])
  status          String   @default("active") // "active" | "canceled" | "past_due" | "suspended" | "trialing"
  paymentMethod   String?  // "pix" | "credit_card"
  // Mercado Pago
  mpCustomerId    String?  // ID do cliente no MP
  mpSubscriptionId String? // ID da assinatura recorrente no MP (cartão)
  // Cobrança
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime? // próximo vencimento
  daysPastDue      Int      @default(0) // dias de atraso (0 = em dia)
  // Trial
  trialStart      DateTime?
  trialEnd        DateTime?
  // Cancelamento
  canceledAt      DateTime?
  cancelReason    String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  payments        Payment[]

  @@index([userId])
  @@index([status])
}

model Payment {
  id              String   @id @default(cuid())
  subscriptionId  String?
  subscription    Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  planId          String?
  plan            SubscriptionPlan? @relation(fields: [planId], references: [id], onDelete: SetNull)
  amount          Float    // valor em R$
  paymentMethod   String   // "pix" | "credit_card" | "boleto"
  status          String   @default("pending") // "pending" | "approved" | "rejected" | "cancelled" | "refunded"
  // Mercado Pago
  mpPaymentId     String?  // ID do pagamento no MP
  mpPreferenceId  String?  // ID da preference (checkout)
  mpPixQrCode     String?  // QR code do PIX (base64 ou texto)
  mpPixQrCodeImage String? // imagem do QR code (data URL)
  mpPixTicketUrl  String?  // URL do boleto/PIX
  // Datas
  dueDate         DateTime? // data de vencimento
  paidAt          DateTime? // data que foi pago
  // CPF do cliente no momento do pagamento (snapshot)
  customerCpf     String?
  customerName    String?
  customerEmail   String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@index([subscriptionId])
}

model System {
  id              String   @id @default(cuid())
  slug            String   @unique
  name            String
  tagline         String
  category        String
  shortDescription String
  longDescription String
  technologies    String   // JSON string array
  highlights      String   // JSON string array
  startingPrice   String?
  status          String   @default("disponivel") // "disponivel" | "sob-consulta"
  featured        Boolean  @default(false)
  accentColor     String   @default("#3b82f6")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  features        Feature[]
  screenshots     Screenshot[]
  benefits        Benefit[]
  plans           Plan[]
  faq             Faq[]
  orders          Order[]
}

model Feature {
  id          String  @id @default(cuid())
  systemId    String
  system      System  @relation(fields: [systemId], references: [id], onDelete: Cascade)
  title       String
  description String
  sortOrder   Int     @default(0)
}

model Screenshot {
  id        String @id @default(cuid())
  systemId  String
  system    System @relation(fields: [systemId], references: [id], onDelete: Cascade)
  label     String
  gradient  String
  sortOrder Int    @default(0)
}

model Benefit {
  id        String @id @default(cuid())
  systemId  String
  system    System @relation(fields: [systemId], references: [id], onDelete: Cascade)
  text      String
  sortOrder Int    @default(0)
}

model Plan {
  id          String   @id @default(cuid())
  systemId    String
  system      System   @relation(fields: [systemId], references: [id], onDelete: Cascade)
  name        String
  price       String
  period      String?
  description String
  features    String   // JSON string array
  highlighted Boolean  @default(false)
  sortOrder   Int      @default(0)
}

model Faq {
  id        String @id @default(cuid())
  systemId  String
  system    System @relation(fields: [systemId], references: [id], onDelete: Cascade)
  question  String
  answer    String
  sortOrder Int    @default(0)
}

model Project {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  description String
  status      String   @default("pending") // "pending" | "in_progress" | "completed" | "cancelled"
  budget      String?
  deadline    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Deploy {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name          String
  repoUrl       String
  branch        String   @default("main")
  framework     String?  // nextjs | vite | cra | static | etc (auto-detected)
  buildCommand  String?
  outputDir     String?
  installCommand String?
  status        String   @default("queued") // queued | building | ready | error
  buildLog      String?
  previewUrl    String?
  errorMessage  String?
  envVars       String   @default("[]") // JSON array of {key, value}
  autoUpdate    Boolean  @default(false) // auto redeploy on git push
  customDomain  String?  // user's custom domain (e.g. meusite.com.br)
  lastCommitSha String?  // last deployed git commit
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  tickets       Ticket[]
}

model Ticket {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  deployId    String?
  deploy      Deploy?  @relation(fields: [deployId], references: [id], onDelete: SetNull)
  subject     String
  message     String
  status      String   @default("open") // open | in_progress | resolved | closed
  priority    String   @default("normal") // low | normal | high | urgent
  response    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Order {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  systemId  String?
  system    System?  @relation(fields: [systemId], references: [id], onDelete: SetNull)
  planName  String?
  price     String?
  status    String   @default("pending") // "pending" | "paid" | "cancelled" | "refunded"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Database {
  id               String   @id @default(cuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name             String   // user-friendly name
  slug             String   // sanitized name used as db name + username
  engine           String   @default("postgresql") // "postgresql" | "mysql" | "redis"
  status           String   @default("active") // "creating" | "active" | "error" | "deleting"
  // Internal connection (for apps deployed on the same VPS)
  internalHost     String   @default("127.0.0.1")
  internalPort     Int      @default(5432)
  dbName           String   // actual database name in PostgreSQL
  dbUser           String   // actual PostgreSQL username
  dbPassword       String   // actual PostgreSQL password (kept internal)
  errorMessage     String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([userId, slug])
  @@index([userId])
}

model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}
